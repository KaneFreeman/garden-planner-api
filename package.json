{
  "name": "garden-planner-backend",
  "version": "1.0.0-beta1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "rimraf dist-prod && nest build -p tsconfig.prod.json --config nest-cli-prod.json",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:restart": "npm run docker:down && docker-compose build --no-cache && npm run docker:up",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "rimraf dist && cross-env NODE_ENV=development nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "cross-env NODE_ENV=production node dist-prod/src/main.js",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\"",
    "test": "node --test --require ts-node/register \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@nestjs-modules/mailer": "2.3.7",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.27",
    "@nestjs/platform-socket.io": "11.1.27",
    "@nestjs/schedule": "6.1.3",
    "@nestjs/swagger": "11.4.4",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "11.1.27",
    "cookie-parser": "1.4.7",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "ejs": "5.0.2",
    "express": "5.2.1",
    "handlebars": "4.7.9",
    "liquidjs": "10.27.0",
    "mjml": "5.3.0",
    "mongoose": "9.7.0",
    "nest-winston": "1.10.2",
    "nodemailer": "8.0.11",
    "preview-email": "3.1.3",
    "pug": "3.0.4",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.1.3",
    "socket.io": "4.8.3",
    "swagger-ui-express": "5.0.1",
    "uuid": "14.0.0",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@types/cookie-parser": "1.4.10",
    "@types/ejs": "3.1.5",
    "@types/express": "5.0.6",
    "@types/mjml": "5.0.0",
    "@types/node": "24.12.2",
    "@types/nodemailer": "8.0.1",
    "@types/pug": "2.0.10",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.61.1",
    "cross-env": "10.1.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "prettier": "3.8.4",
    "source-map-support": "0.5.21",
    "ts-loader": "9.6.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "webpack": "5.107.2"
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          ".prettierrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ],
    "trailingComma": "none",
    "singleQuote": true,
    "printWidth": 120
  },
  "engines": {
    "node": ">=24 <25"
  }
}
